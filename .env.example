# Database
POSTGRES_USER=rasa_admin
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=rasa_knowledge
DATABASE_URL=postgresql+psycopg2://rasa_admin:rasa_password@db:5432/rasa_knowledge

# JWT
# 至少 64 字元的隨機字串（建議 openssl rand -hex 32），禁用範本字串
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# Docker bind mount paths
# TXT_OUTPUT_HOST_PATH  : 主機端實際路徑（Windows 可含磁碟機代號，如 D:/SAP）
# TXT_OUTPUT_CONTAINER_PATH : 容器內路徑（必須為純 Linux 路徑，不含冒號）
#   Linux 部署：兩者填相同值（如 /opt/twlife），agents.txt_output_path 即填此值
#   Windows 開發：HOST=D:/SAP, CONTAINER=/opt/sap，agents.txt_output_path 填容器路徑
# Linux 部署：設為專案根目錄絕對路徑，例如 PROJECT_ROOT=/opt/rasa_rag
# 這樣容器內路徑與主機路徑相同，ingest_script_path 直接填主機路徑即可
# Windows dev：保持 PROJECT_ROOT=. 或不設定
PROJECT_ROOT=.
TXT_OUTPUT_HOST_PATH=D:/SAP
TXT_OUTPUT_CONTAINER_PATH=/opt/sap

# CORS
CORS_ORIGIN=http://localhost:5173

# Application
APP_HOST=0.0.0.0
APP_PORT=8000

# Qdrant 向量資料庫（celery_worker 內 ingest_kb.py 使用，外部服務不在 compose 內）
# 必須含完整 scheme + host + port，例：http://10.2.66.88:6333
QDRANT_URL=http://your-qdrant-host:6333

# ── Embedding Provider 設定 ────────────────────────────────────────────────
# 每個 Agent 可獨立選擇 provider（DB agents.embedding_provider）；以下兩套憑證
# 由 ingest_kb.py 根據 agent 設定取用對應一套：
#
# 1) OpenAI 雲端（agent.embedding_provider='openai'）
OPENAI_API_KEY=
#
# 2) 地端 OpenAI-compatible（agent.embedding_provider='local'）
#    例：LM Studio / Ollama / TEI / vLLM / LocalAI 等
#    base_url 需指向 OpenAI-compatible 端點（含 /v1）
LOCAL_EMBEDDING_BASE_URL=
LOCAL_EMBEDDING_API_KEY=any-non-empty

# Logging
LOG_LEVEL=INFO

# Seed Admin (used on first startup when users table is empty)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=CHANGE_ME_8CHARS
